# ==========================================================================
# .gitignore — PsyConn
# ==========================================================================

# --- R / RStudio (originales) ---
.Rproj.user
.Rhistory
.RData
.Ruserdata

# --- Credenciales / licencias personales ---
# (Solo el license.txt de la raíz, que es una clave de software con
#  credenciales personales — NO confundir con LICENSE/LICENSE-docs.md,
#  que sí se publican. El patrón usa /license.txt con barra inicial
#  para anclarlo a la raíz del repo y evitar matches con LICENSE en
#  sistemas case-insensitive como Windows.)
/license.txt

# --- Entornos y cachés ---
__pycache__/
*.pyc
.DS_Store

# --- Dependencias de terceros con su propio repositorio ---
# NORDIC_Raw (Steen Moeller, UMN). Se documenta en README cómo obtenerlo.
src/external/NORDIC_Raw/

# --- Carpetas raíz completas ---
tools/
TFM/
docs/
Bibliography/

# --- Subcarpetas en reports/ ---
reports/__pycache__/
reports/_archive/

# --- Subcarpetas en notebooks/ ---
notebooks/_archive/

